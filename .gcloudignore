.git
.claude
node_modules
frontend/node_modules
__pycache__
*.pyc
backend/tests
backend/backups
backend/evidence

# Local dev config must NOT ship to Cloud Run — its Windows LOCAL_PARQUET_PATH
# is a dead path on the Linux container and made the app show a bogus
# "Using remote dataset" path. Cloud Run gets its config via --set-env-vars.
.env
backend/.env

# Large data files — never upload to Cloud Build
# NOTE: backend/data/ contains Python modules (duckdb_client.py, etc.)
# so we exclude only the large data artifacts within it, not the dir.
backend/data/*.parquet
backend/data/*.csv
backend/data/*.json
backend/.tmp/
backend/prescan_cache.json
backend/prescan_slim.json
backend/hcpcs_index.parquet
backend/ml_scores.json
backend/supervised_model.json
backend/precomputed_analyses.json
backend/oig_exclusions_cache.json
backend/.prescan_cache_*.tmp
backend/*.tmp
# NOTE: oig_exclusions.json and npi_deactivations.json are reference stores loaded
# SYNCHRONOUSLY at startup (lifespan, before serving) and are NOT pulled from GCS.
# If they are excluded from the image, every cold start has a window where OIG
# exclusions are dark — provable fraud (excluded providers) gets buried and the
# Brain can cache that degraded ranking for the 15-min TTL. So they MUST ship.
# Keep them reasonably fresh by re-downloading during the rescore/deploy cycle.
backend/enrollment_cache.json
backend/users.json
backend/sessions.json
backend/review_queue.json
backend/oig_tips.json
backend/watchlist.json
backend/alert_rules.json
backend/app.db
backend/app.db-shm
backend/app.db-wal
backend/app.db.backup
backend/phi_access_log.json
backend/uvicorn.log
backend/stdout*.log
backend/stderr*.log
deploy-tmp/
frontend/dist/
.firebase/
