# Dependencies
node_modules/
__pycache__/
*.pyc

# Build output
frontend/dist/

# Environment
.env
.env.*
*.env.local
*.env.production

# Data files (large, generated)
backend/prescan_cache.json
backend/review_queue.json
backend/enrollment_cache.json
backend/oig_exclusions.json
backend/data/*.parquet

# Auth / session state — never commit
backend/users.json
backend/sessions.json
backend/.admin_initialized

# SQLite runtime DB — never commit
backend/app.db
backend/app.db-shm
backend/app.db-wal

# Private keys and certificates
*.pem
*.key
*.p12
*.pfx
*-service-account*.json
*-credentials*.json

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Temp files
*.tmp
*.tmp.*

# Firebase
.firebase/

# added by github-push batch
.venv/
venv/
.env.local
.env.*.local
secrets.*
credentials*
# Ignore everything inside .claude/ EXCEPT shared skills and agents that
# should ship with the repo. Use `.claude/*` (children) — NOT `.claude/`
# (the dir itself) — so the negations below can re-include subpaths.
.claude/*
!.claude/skills/
!.claude/agents/
dist/
build/
.next/
*.log
.tmp/
.prescan_cache*
prescan_cache.json
backend/data/*.duckdb
# --- Secrets (never commit) ---
*serviceAccount*.json
*serviceAccountKey*
*firebase-adminsdk*.json
*firebase-sa*.json
*sa-key*.json
.env
.env.local
.env.*.local
!.env.example
backend/precomputed_analyses.json
backend/hcpcs_index.parquet
backend/supervised_model.json
backend/ml_scores.json
